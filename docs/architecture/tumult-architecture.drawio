        <!-- Method -->
        <mxCell id="df-method" value="Execute Method&#xa;&#xa;For each step:&#xa;1. Run controls.before&#xa;2. OTel: START span&#xa;3. Execute action/probe&#xa;4. OTel: END span&#xa;5. Run controls.after&#xa;6. Record result&#xa;7. Pause if specified" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
