              "aggregateOperator": "sum",
              "dataSource": "metrics",
              "disabled": false,
              "expression": "A",
              "filters": {
                "items": [
                  {
                    "id": "f-success",
                    "key": {
                      "dataType": "string",
                      "id": "resilience.outcome.status--string--tag--false",
                      "isColumn": false,
                      "isJSON": false,
                      "key": "resilience.outcome.status",
                      "type": "tag"
                    },
                    "op": "=",
                    "value": "success"
                  }
                ],
                "op": "AND"
              },
              "functions": [],
              "groupBy": [],
              "having": [],
              "legend": "Passed",
              "limit": null,
              "orderBy": [],
