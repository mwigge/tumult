      "description": "Change Failure Rate proxy — ratio of experiments with hypothesis NOT met (system failed under chaos) to total experiments",
      "id": "stat-dora-cfr",
      "panelTypes": "value",
      "query": {
        "builder": {
          "queryData": [
            {
              "aggregateAttribute": {
                "dataType": "float64",
                "id": "tumult.experiments.total--float64--Sum--true",
                "isColumn": true,
                "isJSON": false,
                "key": "tumult.experiments.total",
                "type": "Sum"
              },
              "aggregateOperator": "sum",
              "dataSource": "metrics",
              "disabled": false,
              "expression": "A",
              "filters": {
                "items": [
                  {
                    "id": "f1",
                    "key": {
                      "dataType": "string",
                      "id": "resilience.outcome.status--string--tag--false",
                      "isColumn": false,
                      "isJSON": false,
                      "key": "resilience.outcome.status",
                      "type": "tag"
                    },
                    "op": "=",
                    "value": "deviated"
                  }
                ],
                "op": "AND"
              },
              "functions": [],
              "groupBy": [],
              "having": [],
              "legend": "failures",
              "limit": null,
              "orderBy": [],
              "queryName": "A",
              "reduceTo": "sum",
              "spaceAggregation": "sum",
              "stepInterval": 60,
              "timeAggregation": "increase"
            }
          ],
          "queryFormulas": []
        },
